# API keys for live workbench runs and experiment re-runs.
# Agent under test (agent-4 / agent-4-react) uses OpenAI.
# LLM judge (default: Claude Haiku) uses Anthropic.

OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Alternate providers for workbench / agents
OPENROUTER_API_KEY=your-openrouter-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
GOOGLE_API_KEY=your-google-api-key

# Experiment agents (comparative profiling / mitigation impact)
# agent-1 / agent-1-zero-shot: Gemini 2.5 Flash (OpenRouter or Google AI)
AGENT1_API_KEY=your-openrouter-or-google-key
AGENT1_MODEL=google/gemini-2.5-flash
AGENT1_BASE_URL=https://openrouter.ai/api/v1

# agent-2: DeepSeek V4 Pro (uses DEEPSEEK_API_KEY)
AGENT2_MODEL=deepseek-v4-pro

# agent-3: Llama 3.3 70B via OpenRouter or any OpenAI-compatible endpoint
LLAMA_API_KEY=your-openrouter-or-together-key
LLAMA_MODEL=meta-llama/llama-3.3-70b-instruct
LLAMA_BASE_URL=https://openrouter.ai/api/v1

# Parallelism / retries
AGENTCHECK_WORKERS=8
AGENTCHECK_RATE_LIMIT_RETRIES=5

# SQLite path for bundled comparisons (optional override)
AGENTCHECK_DB_PATH=agentcheck.db
